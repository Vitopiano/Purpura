{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .corporate-contact .field__input {
    font-family: 'Montserrat', sans-serif;
  }

  .corporate-contact__row {
    display: flex;
    gap: 1.5rem;
  }

  .corporate-contact__row .field {
    flex: 1 1 0;
  }

  @media screen and (max-width: 749px) {
    .corporate-contact__row {
      flex-direction: column;
      gap: 0;
    }
  }

  .corporate-contact .button {
    margin-top: 1rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="corporate-contact contact page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <div class="corporate-contact__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'CorporateContactForm', class: contact_form_class -%}
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {{- 'icon-success.svg' | inline_asset_content -}}
          {{ section.settings.success_message | default: '¡Gracias! Hemos recibido tu mensaje y te contactaremos pronto.' }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {{- 'icon-error.svg' | inline_asset_content -}}
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
        </div>
      {%- endif -%}

      <div class="corporate-contact__row">
        <div class="field">
          <input
            class="field__input"
            autocomplete="given-name"
            type="text"
            id="CorporateContactForm-firstname"
            name="contact[Nombre]"
            value="{% if form.first_name %}{{ form.first_name }}{% endif %}"
            placeholder="Nombre"
            required
          >
          <label class="field__label" for="CorporateContactForm-firstname">Nombre</label>
        </div>
        <div class="field">
          <input
            class="field__input"
            autocomplete="family-name"
            type="text"
            id="CorporateContactForm-lastname"
            name="contact[Apellido]"
            placeholder="Apellido"
            required
          >
          <label class="field__label" for="CorporateContactForm-lastname">Apellido</label>
        </div>
      </div>

      <div class="field">
        <input
          class="field__input"
          autocomplete="organization"
          type="text"
          id="CorporateContactForm-company"
          name="contact[Empresa]"
          placeholder="Empresa"
          required
        >
        <label class="field__label" for="CorporateContactForm-company">Empresa</label>
      </div>

      <div class="field">
        <input
          class="field__input"
          autocomplete="tel"
          type="tel"
          id="CorporateContactForm-whatsapp"
          name="contact[Número de WhatsApp]"
          placeholder="Número de WhatsApp"
          required
        >
        <label class="field__label" for="CorporateContactForm-whatsapp">Número de WhatsApp</label>
      </div>

      <div class="field">
        <textarea
          rows="6"
          id="CorporateContactForm-body"
          class="text-area field__input"
          name="contact[Comentarios]"
          placeholder="Comentarios"
        >{{- form.body -}}</textarea>
        <label class="form__label field__label" for="CorporateContactForm-body">Comentarios</label>
      </div>

      <div class="contact__button">
        <button type="submit" class="button button--primary button--full-width">
          {{ section.settings.button_label | default: 'Enviar' }}
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contacto corporativo",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Contacto corporativo",
      "label": "Título"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Cuéntanos sobre tu empresa y nos pondremos en contacto contigo.</p>",
      "label": "Texto debajo del título"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Enviar",
      "label": "Texto del botón"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "¡Gracias! Hemos recibido tu mensaje y te contactaremos pronto.",
      "label": "Mensaje de confirmación"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Contacto corporativo"
    }
  ]
}
{% endschema %}
