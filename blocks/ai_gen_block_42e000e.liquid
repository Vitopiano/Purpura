{% doc %}
  @prompt
    IMAGEN SIN TEXTO. sOLO IMAGEN QUE CAMBIE TIPO DIAPOSITIVAS
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-slideshow-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slide_height }}px;
  }

  .ai-image-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
  }

  .ai-image-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    z-index: 1;
  }

  .ai-image-slideshow__slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-slideshow__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-slideshow__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-slideshow__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 2;
  }

  .ai-image-slideshow__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-image-slideshow__dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.1);
  }

  .ai-image-slideshow__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-image-slideshow__arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 2;
    pointer-events: none;
  }

  .ai-image-slideshow__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.3s ease;
    pointer-events: auto;
  }

  .ai-image-slideshow__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
    transform: scale(1.1);
  }

  .ai-image-slideshow__arrow-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  @media screen and (max-width: 749px) {
    .ai-image-slideshow__container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_slide_height }}px;
    }
  }
{% endstyle %}

<image-slideshow-{{ ai_gen_id }}
  class="ai-image-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-slideshow__container-{{ ai_gen_id }}">
    {% liquid
      assign has_images = false
      for i in (1..5)
        assign image_key = 'image_' | append: i
        if block.settings[image_key] != blank
          assign has_images = true
          break
        endif
      endfor
    %}

    {% if has_images %}
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          <div class="ai-image-slideshow__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index }}">
            <img
              src="{{ image | image_url: width: 2000 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          </div>
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="ai-image-slideshow__slide-{{ ai_gen_id }} active">
        <div class="ai-image-slideshow__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-slideshow__empty-state-{{ ai_gen_id }}">
            Agrega imágenes para crear tu presentación
          </div>
        </div>
      </div>
    {% endif %}
  </div>

  {% if has_images and block.settings.show_arrows %}
    <div class="ai-image-slideshow__arrows-{{ ai_gen_id }}">
      <button class="ai-image-slideshow__arrow-{{ ai_gen_id }} ai-image-slideshow__arrow-prev-{{ ai_gen_id }}" aria-label="Imagen anterior">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-image-slideshow__arrow-{{ ai_gen_id }} ai-image-slideshow__arrow-next-{{ ai_gen_id }}" aria-label="Siguiente imagen">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if has_images and block.settings.show_dots %}
    <div class="ai-image-slideshow__controls-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          <button
            class="ai-image-slideshow__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide="{{ forloop.index }}"
            aria-label="Ir a imagen {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</image-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-image-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-image-slideshow__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-image-slideshow__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-slideshow__arrow-next-{{ ai_gen_id }}');
        
        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        
        const autoplay = this.dataset.autoplay === 'true';
        if (autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.previousSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const speed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, speed);
      }

      resetAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          const autoplay = this.dataset.autoplay === 'true';
          if (autoplay) {
            this.startAutoplay();
          }
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('image-slideshow-{{ ai_gen_id }}', ImageSlideshow{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Presentación de imágenes",
  "settings": [
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Imagen 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Imagen 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Imagen 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Imagen 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Imagen 5"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "slide_height",
      "label": "Altura en escritorio",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_slide_height",
      "label": "Altura en móvil",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Transición"
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Velocidad de transición",
      "min": 0.5,
      "max": 2,
      "step": 0.5,
      "unit": "s",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Velocidad de reproducción",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Controles"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Mostrar puntos",
      "default": true
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Tamaño de puntos",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Color de puntos",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Mostrar flechas",
      "default": true
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Tamaño de flechas",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Fondo de flechas",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_hover_bg_color",
      "label": "Fondo de flechas al pasar",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Color de flechas",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Presentación de imágenes"
    }
  ]
}
{% endschema %}
