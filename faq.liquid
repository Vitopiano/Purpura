{{ 'component-accordion.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .faq__label {
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--purpura-accent);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  .faq__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem;
    font-weight: 400;
    color: var(--purpura-text);
    margin: 0 0 2.5rem;
    text-align: center;
  }

  .faq__list {
    border-top: 0.05rem solid var(--purpura-border);
  }

  .faq__item {
    border-bottom: 0.05rem solid var(--purpura-border);
  }

  .faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.6rem 0;
    cursor: pointer;
    list-style: none;
  }

  .faq__item summary::-webkit-details-marker {
    display: none;
  }

  .faq__question {
    font-family: 'Jost', sans-serif;
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--purpura-text);
    padding-right: 1.5rem;
  }

  .faq__icon {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--purpura-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq__item[open] .faq__icon {
    transform: rotate(180deg);
  }

  .faq__answer {
    font-family: 'Jost', sans-serif;
    font-size: 1.3rem;
    color: var(--purpura-text-secondary);
    line-height: 1.7;
    padding: 0 0 1.8rem;
    max-width: 80rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.label != blank -%}
      <p class="faq__label">{{ section.settings.label | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="faq__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="faq__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <details class="faq__item" {{ block.shopify_attributes }}>
            <summary>
              <span class="faq__question">{{ block.settings.question | escape }}</span>
              <span class="svg-wrapper faq__icon">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </summary>
            <div class="faq__answer rte">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "default": "Ayuda",
      "label": "Texto pequeño superior"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Preguntas frecuentes",
      "label": "Título"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Respuesta.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
